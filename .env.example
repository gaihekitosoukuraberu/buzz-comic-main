# ============================================================
# Buzz Comic — 環境変数テンプレート
# .env.local にコピーして値を設定してください
# ============================================================

# データベース
DATABASE_URL="file:./dev.db"
# 本番（Xserver MySQL）: "mysql://user:pass@host:3306/dbname"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""          # openssl rand -base64 32
AUTH_SECRET=""              # NEXTAUTH_SECRETと同じ値

# 管理者初期パスワード（seedコマンド実行時のみ使用）
# ⚠️ 必ずランダムな強固なパスワードを設定すること
ADMIN_INIT_PASSWORD=""

# FLUX.2 / ComfyUI（ローカル生成）
COMFYUI_API_URL="http://localhost:8188"
FLUX_MODEL="flux1-dev.safetensors"

# ファイルストレージ
UPLOAD_DIR="./public/uploads"
MAX_FILE_SIZE="50mb"

# スコアエンジン
SCORE_CULL_THRESHOLD="10"
SCORE_CULL_DAYS="30"
CRON_SECRET=""              # openssl rand -base64 32

# 収益（要確認: 実際の単価は経営判断で設定）
REVENUE_CPM_RATE="0.5"      # 円 / 1000 views（仮値）
REVENUE_MIN_PAYOUT="1000"   # 最低支払額 円

# Google Sheets（GAS連携）
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_PRIVATE_KEY=""
SHEETS_SPREADSHEET_ID=""
GAS_WEBHOOK_URL=""
GAS_WEBHOOK_SECRET=""

# SNS自動投稿（Puppeteer）⚠️ 認証情報は安全に管理
SNS_TWITTER_USERNAME=""
SNS_TWITTER_PASSWORD=""
SNS_INSTAGRAM_USERNAME=""
SNS_INSTAGRAM_PASSWORD=""
PUPPETEER_HEADLESS="true"

# Xserver
XSERVER_HOST="sv16424.xserver.jp"
XSERVER_USER="xs997058"

# アプリURL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
